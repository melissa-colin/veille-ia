# Copy to .env (gitignored) and fill in. In CI these come from GitHub Secrets.

# ANTHROPIC API key — ONLY needed if engine="api" in pipeline/config.json.
# The default engine="claude-code" uses your local Claude Max plan instead (no key).
ANTHROPIC_API_KEY=

# Voice (sign up at elevenlabs.io — needed for the podcast)
ELEVENLABS_API_KEY=...

# Google Drive delivery (service account JSON, base64- or raw-encoded).
# Locally you can instead rely on an existing rclone remote (see delivery.driveRemote in config.json).
GDRIVE_SA_JSON=
GDRIVE_FOLDER_ID=

# Optional overrides
VEILLE_OUT_DIR=
VEILLE_DRY_RUN=
